{
  "lock": false,
  "nodeModulesDir": "auto",
  "tasks": {
    "check": "deno fmt --check . && deno lint . && deno check",
    "dev": "deno run -A --env scripts/generate-seo.ts && deno run -A --env --unstable-kv npm:vite",
    "build": "deno run -A --env scripts/generate-seo.ts && deno run -A --env --unstable-kv npm:vite build",
    "start": "deno run -A --env scripts/generate-seo.ts && deno serve -A --env --unstable-kv _fresh/server.js",
    "update": "deno run -A -r jsr:@fresh/update ."
  },
  "lint": {
    "rules": {
      "tags": ["fresh", "recommended"],
      "exclude": [
        "no-explicit-any",
        "no-unused-vars",
        "no-empty",
        "react-no-danger",
        "no-window",
        "jsx-button-has-type",
        "ban-ts-comment",
        "jsx-boolean-value",
        "prefer-const"
      ]
    }
  },
  "exclude": ["**/_fresh/*"],
  "imports": {
    "@/": "./",
    "@medusajs/js-sdk": "https://esm.sh/@medusajs/js-sdk@2.15.5",
    "@std/front-matter": "jsr:@std/front-matter@^1.0.9",
    "@tailwindcss/typography": "npm:@tailwindcss/typography@^0.5.16",
    "@medusajs/types": "npm:@medusajs/types@^2.15.5",
    "fresh": "jsr:@fresh/core@^2.3.3",
    "lucide-preact": "npm:lucide-preact",
    "preact": "npm:preact@10.29.1",
    "preact/hooks": "npm:preact@10.29.1/hooks",
    "preact/jsx-runtime": "npm:preact@10.29.1/jsx-runtime",
    "preact/jsx-dev-runtime": "npm:preact@10.29.1/jsx-dev-runtime",
    "preact/compat": "npm:preact@10.29.1/compat",
    "@preact/signals": "npm:@preact/signals",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.0.8",
    "vite": "npm:vite@^7.1.3",
    "@types/babel__core": "npm:@types/babel__core@^7.20.5",
    "tailwindcss": "npm:tailwindcss@^4.1.10",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.1.12",
    "marked": "npm:marked@^14.1.2",
    "@types/marked": "npm:@types/marked@^6.0.0"
  },
  "compilerOptions": {
    "lib": ["dom", "dom.asynciterable", "dom.iterable", "deno.ns"],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": ["vite/client"]
  }
}
